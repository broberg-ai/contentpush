# Contentpush — kopiér til .env og udfyld. .env er gitignored; commit ALDRIG secrets.
# Alle secrets er ship-dark: mangler en værdi, degraderer appen (log-advarsel), den crasher ikke.

# Dev-server port (default 3019)
PORT=3019

# Database — Turso (cloud). Usat = lokal libSQL-fil i .data/ (dev).
# OBS: projekt-præfikset med vilje — brug IKKE generisk TURSO_DATABASE_URL
# (den lækker fra shell-profilen og peger på et andet projekts DB).
CONTENTPUSH_TURSO_URL=
CONTENTPUSH_TURSO_TOKEN=

# Notifikationer (F004) — Discord-webhook. Usat = notify springes over.
DISCORD_WEBHOOK_URL=

# AI-nøgler (F002+) læses af @broberg/ai-sdk selv fra env (fx MISTRAL_API_KEY).
# Tilføjes her når F002 bygges.
